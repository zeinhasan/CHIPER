# ============================================================
# CHIPER - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- SearXNG Configuration ---
# URL of your self-hosted SearXNG instance
SEARXNG_BASE_URL=http://localhost:8080

# SearXNG search categories (comma-separated). Default: "web,news"
# Use "web" for web-only, "web,news" for web+news, or "general" for all categories.
# Narrow categories (e.g. "web") exclude videos, images, and files from search results.
SEARXNG_CATEGORIES=web,news

# --- AI Summarization (OpenAI-compatible) ---
# API key for AI endpoint
CMD_API_KEY=your-api-key-here

# Base URL (OpenAI-compatible)
CMD_BASE_URL=https://openrouter.ai/api/v1

# Model name for summarization & extraction
CMD_MODEL=deepseek/deepseek-chat

# --- Playwright Configuration ---
# Custom browser path (optional, leave empty for default)
# PLAYWRIGHT_BROWSER_PATH=

# --- Server Configuration ---
HOST=0.0.0.0
PORT=8000

# --- Domain Filtering ---
# Global allow/block lists (comma-separated hostnames). Suffix match, so
# "example.com" also covers "www.example.com" and "blog.example.com".
# Empty allowlist = allow all. Block always wins over allow.
# DOMAIN_ALLOWLIST=
# DOMAIN_BLOCKLIST=

# --- Security ---
# API key for authenticating requests via X-API-Key header.
# Leave empty to disable authentication (development only!).
CHIPER_API_KEY=
# Comma-separated list of allowed CORS origins.
# Leave empty to disable CORS entirely (no cross-origin browser access).
CHIPER_CORS_ORIGINS=

# --- Observability ---
# Log format: "json" (structured) or "console" (human-readable)
LOG_FORMAT=json
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Scraping ---
# Minimum characters for Tier-1 to be considered sufficient
# MIN_CONTENT_LENGTH=200
# Maximum response body size in MB before rejecting (Content-Length check)
# SCRAPE_MAX_BODY_MB=50

# --- Reliability: Retry ---
# Number of retries for static fetch (httpx) before escalating to Tier-2
FETCH_STATIC_RETRIES=3
# Number of retries for dynamic fetch (Playwright)
FETCH_DYNAMIC_RETRIES=2
# Base delay in seconds for exponential backoff (1s, 2s, 4s, ...)
FETCH_RETRY_BASE_DELAY=1.0

# --- Reliability: Circuit Breaker ---
# Number of consecutive SearXNG failures before opening the circuit
CIRCUIT_BREAKER_FAILURES=5
# Seconds to wait before trying SearXNG again
CIRCUIT_BREAKER_TIMEOUT=30.0

# --- Reliability: Rate Limiting ---
# Maximum requests per client (format: "N/minute", "N/second", etc.)
RATE_LIMIT=30/minute
# Separate rate limit for crawl & extract endpoint (default: 5/minute)
CRAWL_RATE_LIMIT=5/minute

# --- Crawl ---
# Maximum concurrent scrapes per crawl
CRAWL_MAX_CONCURRENT=5
# Per-page delay in milliseconds for rate limiting
CRAWL_DELAY_MS=500
# Total timeout for sync crawl operations in seconds (default 300 = 5 min)
# CRAWL_TOTAL_TIMEOUT=300

# --- Map Discovery ---
# Maximum concurrent requests during site map discovery
# MAP_MAX_CONCURRENT=10
# Per-page delay during map discovery in milliseconds
# MAP_DELAY_MS=200
# Total timeout for sync map operations in seconds (default 120 = 2 min)
# MAP_TOTAL_TIMEOUT=120
# Total timeout for extraction operations (sync + async) in seconds (default 300 = 5 min)
# EXTRACT_TOTAL_TIMEOUT=300
# Total timeout for the async research scraping phase in seconds (default 300 = 5 min)
# RESEARCH_TOTAL_TIMEOUT=300

# --- PDF Scraping ---
# Enable PDF download & text extraction (via pymupdf). Default: true
# PDF_ENABLED=true
# Maximum PDF pages to extract per document. Default: 50
# PDF_MAX_PAGES=50

# --- Persistent History ---
# Enable saving request history to a database. Default: true
# HISTORY_ENABLED=true
# Database URL. Default SQLite; set to postgresql+asyncpg://user:pass@host/db for Postgres.
# DATABASE_URL=sqlite+aiosqlite:///./chiper_history.db
# Days to keep history before purge (0 = keep forever). Default: 30
# HISTORY_RETENTION_DAYS=30
# Store full result content (true) or compact summary only (false). Default: false
# HISTORY_STORE_FULL_CONTENT=false

# --- Browser Pool ---
# Number of Chromium instances for round-robin load distribution
BROWSER_POOL_SIZE=2

# --- Extraction ---
# Maximum number of URLs per extraction request
# EXTRACT_MAX_URLS=20
# Maximum content characters per URL sent to the LLM
# EXTRACT_MAX_CONTENT_CHARS=8000
# LLM temperature for extraction (lower = more deterministic)
# EXTRACT_TEMPERATURE=0.1
# Number of retries if LLM returns invalid JSON (schema mode only)
# EXTRACT_RETRIES=1

# --- Security: Background Task Limits ---
# Maximum concurrent background tasks (0 = unlimited)
# MAX_INFLIGHT_TASKS=0
