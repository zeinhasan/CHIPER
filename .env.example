# ============================================================
# CHIPER - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- SearXNG Configuration ---
# URL of your self-hosted SearXNG instance
SEARXNG_BASE_URL=http://localhost:8080

# --- AI Summarization (CommandCode + DeepSeek) ---
# API key for CommandCode AI endpoint
CMD_API_KEY=your-api-key-here

# CommandCode base URL (OpenAI-compatible)
CMD_BASE_URL=https://api.commandcode.ai/provider/v1

# Model name for summarization
CMD_MODEL=deepseek/deepseek-v4-pro

# --- Playwright Configuration ---
# Custom browser path (optional, leave empty for default)
# PLAYWRIGHT_BROWSER_PATH=

# --- Server Configuration ---
HOST=0.0.0.0
PORT=8000

# --- Observability ---
# Log format: "json" (structured) or "console" (human-readable)
LOG_FORMAT=json
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
